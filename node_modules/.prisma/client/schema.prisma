// Prisma schema for the Intelligent Media Processing Pipeline
// DB: PostgreSQL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ImageStatus {
  pending
  processing
  completed
  failed
}

model Image {
  id            String      @id @default(uuid())
  originalName  String
  storagePath   String
  mimeType      String
  sizeBytes     Int
  status        ImageStatus @default(pending)
  failureReason String?
  attempts      Int         @default(0)

  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  processingStartedAt DateTime?
  processingEndedAt   DateTime?

  results AnalysisResult[]

  @@index([status])
  @@index([createdAt])
}

// One row per check, rather than one giant JSON blob on Image.
// Reasoning: lets us query/aggregate per-check-type later (e.g. "how many
// images failed blur detection this week"), add new checks without a
// migration, and store partial results if some checks succeed and others
// don't within the same job.
model AnalysisResult {
  id      String @id @default(uuid())
  imageId String
  image   Image  @relation(fields: [imageId], references: [id], onDelete: Cascade)

  checkName  String // e.g. "blur", "brightness", "duplicate", "screenshot", "plate_ocr"
  passed     Boolean // did the image pass this check (true = no issue detected)
  confidence Float? // 0-1 where applicable; null if not meaningful for this check
  details    Json // check-specific structured output (scores, extracted text, etc.)

  createdAt DateTime @default(now())

  @@index([imageId])
  @@index([checkName])
}
