# PostgreSQL connection string
DATABASE_URL="postgresql://postgres:root2921@localhost:5432/vehicle_pipeline?schema=public"

# Redis connection (used by BullMQ)
REDIS_HOST=localhost
REDIS_PORT=6379
# App
PORT=3000
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=10
# Duplicate detection sensitivity (0-64, lower = stricter match on pHash hamming distance)
DUPLICATE_HAMMING_THRESHOLD=6
# Job retry config
JOB_MAX_ATTEMPTS=3
JOB_BACKOFF_MS=2000